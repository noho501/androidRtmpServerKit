<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-screen video surface -->
    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Overlay info panel at top -->
    <LinearLayout
        android:id="@+id/infoPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="#AA000000"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvRtmpUrl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="rtmp://&lt;device-ip&gt;:1935/live"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvStreamKey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Stream key: test"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Status indicator at top right -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="#AA000000"
        android:padding="8dp"
        android:text="Waiting for stream…"
        android:textColor="#FFFFFF"
        android:textSize="13sp" />

</FrameLayout>
